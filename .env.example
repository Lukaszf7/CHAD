# ============================================================
# CHAD Voice Assistant — environment configuration
# ============================================================
# Copy this file to a new file named ".env" in the same folder,
# then fill in your real values. ".env" is gitignored, so your
# secrets will never be committed or uploaded.
#
# Everything in THIS file is a secret or a machine-specific
# setting. Everything else (voice, personality, thresholds,
# wake word sensitivity, etc.) lives in data/config.json instead,
# because those are safe to share and don't need to be secret.
# ============================================================

# --- Required ---------------------------------------------------
# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
# Used for: chat responses (GPT) and speech-to-text (Whisper/transcribe).
OPENAI_API_KEY=

# --- Optional: only needed if you enable these providers in config.json ---
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# --- Optional: machine-specific overrides ------------------------
# Uncomment and change any of these to override data/config.json
# without editing that file. Useful for per-machine differences
# (e.g. a quieter microphone on your laptop vs desktop).

# LOG_LEVEL=INFO
# CONFIG_PATH=data/config.json
# WAKE_WORD_MODEL_PATH=models/jerry_wakeword.onnx
